{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "img/**", "use": "@vercel/static" },
    { "src": "video/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth/google",   "dest": "/api/auth/google.js" },
    { "src": "/api/auth/callback", "dest": "/api/auth/callback.js" },
    { "src": "/",                  "dest": "/home.html" },
    { "src": "/login",             "dest": "/login.html" },
    { "src": "/home",              "dest": "/home.html" },
    { "src": "/create",            "dest": "/CreateBook.html" },
    { "src": "/(.*\\.html)",       "dest": "/$1" },
    { "src": "/(.*)",              "dest": "/$1" }
  ]
}
